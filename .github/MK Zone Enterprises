<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MK Zone Enterprises</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial, sans-serif;
}

html{
scroll-behavior:smooth;
}

body{
background:#f8f8f8;
color:#333;
}

/* Hero Section */
.hero{
height:100vh;
background:url('https://i.ibb.co/jZGrBbz6/IMG-5828.jpg') center/cover no-repeat;
display:flex;
align-items:center;
justify-content:center;
text-align:center;
position:relative;
}

.hero::before{
content:"";
position:absolute;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.45);
}

.hero-content{
position:relative;
z-index:2;
color:white;
}

.hero h1{
font-size:4rem;
margin-bottom:15px;
}

.hero p{
font-size:1.4rem;
margin-bottom:25px;
}

.btn{
display:inline-block;
padding:15px 35px;
background:#ff9800;
color:white;
text-decoration:none;
border-radius:30px;
font-weight:bold;
transition:.3s;
}

.btn:hover{
background:#e68900;
}

/* Section Title */
.section-title{
text-align:center;
font-size:2.5rem;
padding:50px 0 20px;
}

/* Carousel */
.carousel-container{
overflow:hidden;
width:90%;
max-width:1200px;
margin:auto;
border-radius:15px;
}

.carousel{
display:flex;
animation:slide 16s infinite;
}

.carousel img{
width:100%;
min-width:100%;
height:500px;
object-fit:cover;
}

@keyframes slide{
0%,20%{transform:translateX(0);}
25%,45%{transform:translateX(-100%);}
50%,70%{transform:translateX(-200%);}
75%,95%{transform:translateX(-300%);}
100%{transform:translateX(0);}
}

/* Products */
.products{
padding:60px 20px;
}

.product-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
max-width:1200px;
margin:auto;
}

.product-card{
background:white;
padding:15px;
border-radius:15px;
box-shadow:0 4px 12px rgba(0,0,0,.1);
text-align:center;
}

.product-card img{
width:100%;
height:250px;
object-fit:cover;
border-radius:10px;
}

.product-card h3{
margin-top:15px;
}

/* Order Form */
.order-section{
padding:70px 20px;
background:white;
}

.order-form{
max-width:700px;
margin:auto;
background:#f7f7f7;
padding:30px;
border-radius:15px;
box-shadow:0 5px 15px rgba(0,0,0,.1);
}

.order-form input,
.order-form textarea,
.order-form select{
width:100%;
padding:12px;
margin:10px 0;
border:1px solid #ddd;
border-radius:8px;
}

.order-form button{
width:100%;
padding:15px;
background:#ff9800;
color:white;
border:none;
border-radius:8px;
font-size:16px;
cursor:pointer;
}

.order-form button:hover{
background:#e68900;
}

/* Footer */
footer{
background:#111;
color:white;
text-align:center;
padding:20px;
}

@media(max-width:768px){
.hero h1{
font-size:2.5rem;
}

.carousel img{
height:300px;
}
}
</style>
</head>
<body>

<!-- Hero Section -->
<section class="hero">
<div class="hero-content">
<h1>MK Zone Enterprises</h1>
<p>Get The Glow With MK Zone</p>
<a href="#products" class="btn">Shop Now</a>
</div>
</section>

<!-- Carousel -->
<h2 class="section-title">Featured Products</h2>

<div class="carousel-container">
<div class="carousel">
<img src="https://i.ibb.co/jZGrBbz6/IMG-5828.jpg">
<img src="https://i.ibb.co/rRBmRQSC/IMG-5832.png">
<img src="https://i.ibb.co/S451f8N6/IMG-5821.jpg">
<img src="https://i.ibb.co/VR49YBr/IMG-5824.jpg">
</div>
</div>

<!-- Products -->
<section id="products" class="products">
<h2 class="section-title">Our Products</h2>

<div class="product-grid">

<div class="product-card">
<img src="https://i.ibb.co/jZGrBbz6/IMG-5828.jpg">
<h3>MK Premium Skincare</h3>
<p>Healthy & Radiant Skin Care.</p>
</div>

<div class="product-card">
<img src="https://i.ibb.co/rRBmRQSC/IMG-5832.png">
<h3>Glow Collection</h3>
<p>Daily Skin Protection & Care.</p>
</div>

<div class="product-card">
<img src="https://i.ibb.co/S451f8N6/IMG-5821.jpg">
<h3>Beauty Essentials</h3>
<p>Premium Quality Products.</p>
</div>

<div class="product-card">
<img src="https://i.ibb.co/VR49YBr/IMG-5824.jpg">
<h3>Natural Care</h3>
<p>Made For Every Skin Type.</p>
</div>

</div>
</section>

<!-- Order Form -->
<section class="order-section">
<h2 class="section-title">Place Your Order</h2>

<form class="order-form">

<input type="text" placeholder="Customer Name" required>

<input type="tel" placeholder="Mobile Number" required>

<input type="email" placeholder="Email Address" required>

<select required>
<option value="">Select Product</option>
<option>MK Premium Skincare</option>
<option>Glow Collection</option>
<option>Beauty Essentials</option>
<option>Natural Care</option>
</select>

<input type="number" placeholder="Quantity" required>

<textarea rows="5" placeholder="Delivery Address" required></textarea>

<button type="submit">Place Order</button>

</form>
</section>

<footer>
<p>MK Zone Enterprises</p>
<p>Email: kushal6283@gmail.com</p>
<p>© 2026 All Rights Reserved</p>
</footer>

</body>
</html>
